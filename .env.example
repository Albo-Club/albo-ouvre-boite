# All of these are wired up by `pnpm setup` — you usually don't need to edit
# this file by hand. Listed here as a reference and for power users who want
# to skip the wizard.

# ─── Convex ────────────────────────────────────────────────────────────────
# Auto-written by `pnpm exec convex dev` on first run. Don't fill manually.
CONVEX_DEPLOYMENT=
VITE_CONVEX_URL=
# Same as VITE_CONVEX_URL with .cloud → .site (wizard does this for you).
VITE_CONVEX_SITE_URL=

# ─── Better Auth ────────────────────────────────────────────────────────────
# BETTER_AUTH_SECRET lives in the Convex env (not here). Auto-generated by
# `pnpm setup`; in prod, `pnpm setup:prod` generates a fresh one.
# BETTER_AUTH_URL also lives in the Convex env; default = http://localhost:3000.

# ─── Anthropic ──────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY lives in the Convex env (not here).
# → Get yours: https://console.anthropic.com/settings/keys

# ─── Resend ─────────────────────────────────────────────────────────────────
# RESEND_API_KEY and RESEND_FROM live in the Convex env (not here).
# → API key:        https://resend.com/api-keys
# → Verified domain: https://resend.com/domains  (use onboarding@resend.dev for dev)

# ─── Sentry (optional, front-end) ──────────────────────────────────────────
# Back-end (SENTRY_DSN, SENTRY_*) lives in the Convex env. Front-end DSN below
# is build-time inlined into the bundle.
# → Get yours: https://sentry.io/settings/{org}/projects/{project}/keys/
VITE_SENTRY_DSN=
