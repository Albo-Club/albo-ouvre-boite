{
  "name": "albo-l-ouvre-boite",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n vite,convex -c blue,magenta \"pnpm dev:vite\" \"pnpm dev:convex\"",
    "dev:vite": "vite dev",
    "dev:convex": "convex dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "sync:skills": "node scripts/sync-skills.mjs",
    "sync:skills:check": "node scripts/sync-skills.mjs --check",
    "init": "node scripts/init.mjs",
    "upgrade-template": "node scripts/upgrade-template.mjs",
    "test:smoke": "node scripts/e2e-smoke.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@convex-dev/agent": "^0.6.1",
    "@convex-dev/better-auth": "^0.12.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@convex-dev/resend": "^0.2.3",
    "@convex-dev/workpool": "^0.4.6",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@sentry/react": "^10.52.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-router": "1.168.26",
    "@tanstack/react-router-with-query": "1.130.17",
    "@tanstack/react-start": "1.167.65",
    "ai": "^6.0.177",
    "better-auth": "^1.6.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.36.1",
    "convex-helpers": "^0.1.116",
    "lucide-react": "^0.469.0",
    "nitro": "3.0.260429-beta",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.2.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/react-router": "1.168.26",
      "@tanstack/react-start": "1.167.65",
      "@tanstack/router-core": "1.169.2",
      "better-call": "1.3.4"
    }
  }
}
